# Pictovap example configuration
# Copy this file to .env and fill values locally.
# Do not commit real credentials.

PICTOVAP_PROFILE=sample-publisher

# Optional CMS adapter configuration
CMS_TYPE=wordpress
CMS_URL=
CMS_USER=
CMS_APP_PASSWORD=

# Optional image source adapters
UNSPLASH_ACCESS_KEY=

# Planned adapter / not used by the credential-free demo
DEPOSITPHOTOS_API_KEY=
DEPOSITPHOTOS_USERNAME=
DEPOSITPHOTOS_PASSWORD=

# Optional local visual memory path
PICTOVAP_VISUAL_MEMORY_DB=
