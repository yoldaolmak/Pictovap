# Pictovap example configuration
# Copy this file to .env and fill values locally.
# Do not commit real credentials.

PICTOVAP_PROFILE=sample-publisher

# Optional: WordPress CMS adapter (services/wordpress.py)
WP_URL=
WP_USER=
WP_APP_PASSWORD=

# Optional: Ghost CMS adapter (publishers/ghost.py)
GHOST_URL=
GHOST_ADMIN_API_KEY=

# Optional: Strapi CMS adapter (publishers/strapi.py)
STRAPI_URL=
STRAPI_API_TOKEN=

# Optional image source adapters
UNSPLASH_ACCESS_KEY=
PICTOVAP_LOCAL_IMAGE_DIR=
DEPOSIT_API_KEY=
DEPOSIT_LOGIN_USER=
DEPOSIT_LOGIN_PASSWORD=
PEXELS_API_KEY=
# Openverse (openverse.org) requires no key -- add "openverse" to a
# profile's image_sources to use it.

# Optional: vision-backed metadata generation. See the Configuration
# Reference (docs/reference/configuration.md) for the variable name --
# not scaffolded here by design.
