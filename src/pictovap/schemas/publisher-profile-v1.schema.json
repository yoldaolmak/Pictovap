{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pictovap.dev/schemas/publisher-profile-v1.schema.json",
  "title": "Pictovap Publisher Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "brand_name"],
  "properties": {
    "schema_version": {"const": 1},
    "profile_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "brand_name": {"type": "string", "minLength": 1},
    "cms_type": {"type": "string", "minLength": 1},
    "language": {"type": "string", "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]{2,8})*$"},
    "language_mode": {"enum": ["fallback", "override"]},
    "image_sources": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "output_rules": {"type": "object"},
    "filename_rules": {"type": "object"},
    "alt_text_rules": {"type": "object"},
    "caption_rules": {"type": "object"},
    "editorial_preferences": {"type": "object"},
    "forbidden_patterns": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
